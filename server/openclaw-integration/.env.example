# AOCN OpenClaw Integration — Environment Variables
# Copy this file to .env and fill in your values

# ── Scraper Config ──
SCRAPE_INTERVAL=15              # Seconds between each scrape cycle
CDP_ENDPOINT=ws://chromium:9222 # Chrome DevTools Protocol endpoint
API_WEBHOOK_URL=                # Optional: POST scraped data to this URL
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ── Telegram Bot (optional, only if using --profile bot) ──
TELEGRAM_BOT_TOKEN=             # Get from @BotFather on Telegram
DISCORD_WEBHOOK_URL=            # Optional: Discord webhook for alerts
ALERT_THRESHOLD_PCT=5           # Minimum spread % to trigger alert

# ── Vercel API (for pushing data to your deployed site) ──
VERCEL_API_URL=https://aocn-ten.vercel.app/api
